# OAuth credentials created in Google Cloud Console (Credentials > OAuth client ID)
GOOGLE_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxx

# Full callback URL, MUST exactly match the one registered in Google Console
# (Authorized redirect URIs).
# Local:  http://localhost:8080/auth/callback
# Prod :  https://hello-ov0m.onrender.com/auth/callback
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/callback

# Secret key used to sign session cookies.
# Generate a strong random value, for example:
#   openssl rand -base64 32
SESSION_SECRET=replace-me-with-a-long-random-value
ALLOWED_EMAILS=other.email@example.com,other2.email@example.com

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/database

# Server listen port (Render injects this variable automatically;
# you don't need to set it on Render).
PORT=8080
